<aside id="sidebar" role="navigation" aria-label="Main navigation">
  <div class="sidebar-inner">

    <!-- Profile -->
    <div class="sidebar-profile">
      {% if site.profile_pic %}
        <a href="{{ '/' | relative_url }}" class="sidebar-avatar-link">
          <img
            src="{{ '/assets/img/' | append: site.profile_pic | relative_url }}"
            alt="{{ site.first_name }} {{ site.last_name }}"
            class="sidebar-avatar"
          />
        </a>
      {% endif %}
      <a class="sidebar-name" href="{{ '/' | relative_url }}">
        <span class="font-weight-bold">{{ site.first_name }}</span>
        {% if site.middle_name %} {{ site.middle_name }}{% endif %}
        {{ site.last_name }}
      </a>
      {% if site.description %}
        <p class="sidebar-desc">{{ site.description | truncatewords: 12 }}</p>
      {% endif %}
    </div>

    <!-- Nav links -->
    <nav class="sidebar-nav">
      <ul>
        {% for p in site.pages %}
          {% if p.permalink == '/' %} {% assign about_title = p.title %} {% endif %}
        {% endfor %}

        <li class="{% if page.permalink == '/' %}active{% endif %}">
          <a href="{{ '/' | relative_url }}">{{ about_title }}</a>
        </li>

        {% assign sorted_pages = site.pages | sort: 'nav_order' %}
        {% for p in sorted_pages %}
          {% if p.nav and p.autogen == null %}
            {% unless p.dropdown %}
              {% assign parent_link = p.permalink | remove: 'index.html' %}
              <li class="{% if page.url contains parent_link %}active{% endif %}">
                {%- if p.permalink contains '://' -%}
                  {%- assign url = p.permalink -%}
                {%- elsif p.permalink contains '/blog/' -%}
                  {%- assign url = '/blog/' -%}
                {%- else -%}
                  {%- assign url = p.url -%}
                {%- endif %}
                <a href="{{ url | relative_url }}">{{ p.title }}</a>
              </li>
            {% endunless %}
          {% endif %}
        {% endfor %}
      </ul>
    </nav>

    <!-- Footer: socials + controls -->
    <div class="sidebar-footer">
      <div class="sidebar-social">
        {% if site.data.socials.email %}
          <a href="mailto:{{ site.data.socials.email }}" title="Email"><i class="fa-solid fa-envelope"></i></a>
        {% endif %}
        {% if site.data.socials.scholar_userid %}
          <a href="https://scholar.google.com/citations?user={{ site.data.socials.scholar_userid }}" title="Google Scholar" target="_blank" rel="noopener"><i class="ai ai-google-scholar"></i></a>
        {% endif %}
        {% if site.data.socials.orcid_id %}
          <a href="https://orcid.org/{{ site.data.socials.orcid_id }}" title="ORCID" target="_blank" rel="noopener"><i class="ai ai-orcid"></i></a>
        {% endif %}
        {% if site.data.socials.github_username %}
          <a href="https://github.com/{{ site.data.socials.github_username }}" title="GitHub" target="_blank" rel="noopener"><i class="fa-brands fa-github"></i></a>
        {% endif %}
        {% if site.data.socials.linkedin_username %}
          <a href="https://linkedin.com/in/{{ site.data.socials.linkedin_username }}" title="LinkedIn" target="_blank" rel="noopener"><i class="fa-brands fa-linkedin"></i></a>
        {% endif %}
        {% if site.data.socials.researchgate_username %}
          <a href="https://www.researchgate.net/profile/{{ site.data.socials.researchgate_username }}" title="ResearchGate" target="_blank" rel="noopener"><i class="ai ai-researchgate"></i></a>
        {% endif %}
        {% if site.data.socials.cv_pdf %}
          <a href="{{ site.data.socials.cv_pdf | relative_url }}" title="CV" target="_blank" rel="noopener"><i class="ai ai-cv"></i></a>
        {% endif %}
      </div>
      <div class="sidebar-controls">
        {% if site.search_enabled %}
          <button id="search-toggle" title="Search" onclick="openSearchModal()">
            <i class="fa-solid fa-magnifying-glass"></i>
          </button>
        {% endif %}
        {% if site.enable_darkmode %}
          <button id="light-toggle" title="Change theme">
            <i class="fa-half-sun-moon" id="light-toggle-system"></i>
            <i class="fa-solid fa-moon" id="light-toggle-dark"></i>
            <i class="fa-solid fa-sun" id="light-toggle-light"></i>
          </button>
        {% endif %}
      </div>
    </div>

  </div>
</aside>

{% if site.enable_progressbar %}
  <progress id="progress" value="0">
    <div class="progress-container">
      <span class="progress-bar"></span>
    </div>
  </progress>
{% endif %}
